#!/usr/bin/env bash
# tasks-init — initialize a git repo for task sync with git-remote-tasks.
#
# Matches `git init [path]` semantics: operates in the current directory
# by default, or creates and enters <path> when given.

set -euo pipefail

FORMAT=""
TARGET=""

usage() {
  cat <<'USAGE'
tasks-init — initialize a git repo for task sync with git-remote-tasks.

Usage:
  tasks-init [--format yaml|org] [path]
  tasks-init --help

Behaviour:
  - If <path> is given, create it (if missing) and cd into it, then run
    `git init`. Mirrors `git init [path]`.
  - If --format is not given, prompt interactively for yaml or org.
  - Writes `[tasks] format = <choice>` into .git/config.
  - Creates tasks/ with a .gitkeep and a minimal .gitignore.
  - Makes an initial commit "tasks: init (<format> format)".
  - Prints next steps for adding a remote.

After the fetch path in FEAT-05 lands, `git merge <remote>/main` no
longer needs `--allow-unrelated-histories` for incremental fetches.
The first fetch still creates a root commit on the remote-tracking
ref, so the initial merge in step 3 below keeps the flag.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --format)
      FORMAT="${2:-}"
      shift 2
      ;;
    --dir)
      # Deprecated alias for the positional form; still honored so
      # previously-pasted READMEs keep working. Prefer the positional.
      TARGET="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "tasks-init: unknown option: $1" >&2
      exit 2
      ;;
    *)
      if [[ -n "$TARGET" ]]; then
        echo "tasks-init: too many positional arguments" >&2
        exit 2
      fi
      TARGET="$1"
      shift
      ;;
  esac
done

if [[ -n "$TARGET" ]]; then
  mkdir -p "$TARGET"
  cd "$TARGET"
fi

if [[ -z "$FORMAT" ]]; then
  while true; do
    read -rp "Choose task file format [yaml/org]: " FORMAT
    case "$FORMAT" in
      yaml|org) break ;;
      *) echo "  → please enter 'yaml' or 'org'." ;;
    esac
  done
fi

case "$FORMAT" in
  yaml|org) ;;
  *)
    echo "tasks-init: --format must be 'yaml' or 'org' (got: $FORMAT)" >&2
    exit 2
    ;;
esac

if [[ ! -d .git ]]; then
  git init --quiet
fi

git config --local tasks.format "$FORMAT"

if [[ ! -f .gitignore ]]; then
  cat > .gitignore <<'EOF'
# git-remote-tasks: nothing task-specific is ignored by default.
EOF
fi

mkdir -p tasks
touch tasks/.gitkeep

git add .gitignore tasks/.gitkeep
# Guard against nothing-to-commit when re-running.
if ! git diff --cached --quiet; then
  git commit --quiet -m "tasks: init ($FORMAT format)"
fi

cat <<EOF

Repo initialized with task format: $FORMAT

Next steps:
  1. Install helper symlinks (once per machine):
       python git_remote_tasks.py install --bin-dir ~/.local/bin

  2. Configure one or more remotes. Example for Vikunja:
       git remote add vikunja vikunja://localhost:3456
       git config tasks-remote.vikunja.scheme    vikunja
       git config tasks-remote.vikunja.baseUrl   http://localhost:3456
       git config tasks-remote.vikunja.apiToken  YOUR_TOKEN

  3. Pull tasks (first fetch only needs --allow-unrelated-histories):
       git fetch vikunja
       git merge vikunja/main --allow-unrelated-histories
       ls tasks/

  4. Push edits:
       \$EDITOR tasks/vikunja-42.$FORMAT
       git add tasks/
       git commit -m "tasks: tweak priority"
       git push vikunja main
EOF
